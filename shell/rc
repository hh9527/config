SHELL_TYPE="$(basename "$SHELL")"

[ -f "$HOME/.config/shell/env" ] && source "$HOME/.config/shell/env"

[ -x "$HOME/.local/bin/mise" ] && eval "$("$HOME/.local/bin/mise" activate "$SHELL_TYPE")"
command -v broot >/dev/null && eval "$(broot --print-shell-function "$SHELL_TYPE")"

if LSD_PATH="$(command -v lsd)" && [ -x "$LSD_PATH" ]; then
	alias ls="$LSD_PATH"
	alias ll="$LSD_PATH -alF"
	alias la="$LSD_PATH -A"
	unset LSD_PATH
fi
